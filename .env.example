# PolyDashboard environment
#
# All values here are SERVER-ONLY. They are read exclusively by lib/pm/proxy.ts
# (imported only from the /app/api/* route handlers) and are NEVER exposed to the
# browser bundle. Do not prefix any of these with NEXT_PUBLIC_.
#
# These three are OPTIONAL overrides for the upstream Polymarket base URLs. Leave
# them unset to use the production defaults baked into lib/pm/proxy.ts.
PM_GAMMA_URL=https://gamma-api.polymarket.com
PM_CLOB_URL=https://clob.polymarket.com
PM_DATA_URL=https://data-api.polymarket.com

# ── CLOB V2 execution (NOT used yet — documented for the later execution phase) ──
# When order signing is added it runs SERVER-SIDE ONLY. Secrets such as the
# private key / API credentials must live here and never reach client code.
# PM_PRIVATE_KEY=
# PM_CLOB_API_KEY=
# PM_CLOB_API_SECRET=
# PM_CLOB_API_PASSPHRASE=
# PM_BUILDER_CODE=
